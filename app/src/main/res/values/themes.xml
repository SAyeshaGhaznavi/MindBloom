<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MindBloom" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary_color</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent_pink</item>
        <item name="android:statusBarColor">@color/bg_main</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.MindBloom.Splash" parent="Theme.MindBloom">
        <item name="android:windowBackground">@color/bg_main</item>
        <item name="android:statusBarColor">@color/bg_main</item>
    </style>

    <style name="BubbleButton" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/bubble_button_bg</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:elevation">2dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>
</resources>