<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Profile Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/soft_gradient_card_bg"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/circle_icon_bg"
                android:gravity="center"
                android:elevation="4dp"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/account"
                    android:textSize="32sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvStudentName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="student name"
                android:textSize="20sp"
                android:textColor="@color/text_dark"
                android:fontFamily="sans-serif-light"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvGrade"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="grade level"
                android:textSize="13sp"
                android:textColor="@color/text_medium"
                android:fontFamily="sans-serif-light" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutParentSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/feature_card_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="20dp"
            android:layout_marginBottom="24dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/parent"
                android:textSize="24sp"
                android:layout_marginEnd="16dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="parents settings"
                    android:textSize="16sp"
                    android:textColor="@color/text_dark"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="manage screen time and content safety"
                    android:textSize="11sp"
                    android:textColor="@color/text_light"
                    android:fontFamily="sans-serif-light"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textSize="24sp"
                android:textColor="@color/text_light"/>
        </LinearLayout>

        <!-- Account Settings -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="account"
            android:textSize="13sp"
            android:textColor="@color/text_light"
            android:fontFamily="sans-serif-light"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/feature_card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <!-- NEW: Edit Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Change name"
                android:textSize="12sp"
                android:textColor="#000000"
                android:fontFamily="sans-serif-light"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bubble_input_bg"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_dark"
                android:textSize="14sp"
                android:hint="Enter name"
                android:inputType="textPersonName"
                android:fontFamily="sans-serif-light"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Change email"
                android:textSize="12sp"
                android:textColor="#000000"
                android:fontFamily="sans-serif-light"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bubble_input_bg"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_dark"
                android:textSize="14sp"
                android:hint="Enter email"
                android:inputType="textEmailAddress"
                android:fontFamily="sans-serif-light"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnConfirm"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Confirm"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:fontFamily="sans-serif-light"
                android:background="@drawable/outlined_button_bg" />
        </LinearLayout>

        <!-- ══════════════════════════════════ -->
        <!-- NEW: Preferences Section -->
        <!-- ══════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="preferences"
            android:textSize="13sp"
            android:textColor="@color/text_light"
            android:fontFamily="sans-serif-light"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/feature_card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <!-- Notifications -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="push notifications"
                        android:textSize="14sp"
                        android:textColor="@color/text_dark"
                        android:fontFamily="sans-serif-light" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="homework and quiz reminders"
                        android:textSize="11sp"
                        android:textColor="@color/text_light"
                        android:fontFamily="sans-serif-light" />
                </LinearLayout>

                <Switch
                    android:id="@+id/switchNotifications"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/primary_color"
                    android:trackTint="@color/primary_light" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0EEF5" />

            <!-- Language -->
            <LinearLayout
                android:id="@+id/layoutLanguage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="language"
                        android:textSize="14sp"
                        android:textColor="@color/text_dark"
                        android:fontFamily="sans-serif-light" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="English"
                    android:textSize="13sp"
                    android:textColor="@color/text_medium"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="24sp"
                    android:textColor="@color/text_light"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Accessibility Settings -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="accessibility"
            android:textSize="13sp"
            android:textColor="@color/text_light"
            android:fontFamily="sans-serif-light"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/feature_card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <!-- Voice Control -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="voice control"
                        android:textSize="14sp"
                        android:textColor="@color/text_dark"
                        android:fontFamily="sans-serif-light" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="for visually impaired users"
                        android:textSize="11sp"
                        android:textColor="@color/text_light"
                        android:fontFamily="sans-serif-light" />
                </LinearLayout>

                <Switch
                    android:id="@+id/switchVoiceControl"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/primary_color"
                    android:trackTint="@color/primary_light" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0EEF5" />

            <!-- High Contrast -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="high contrast"
                        android:textSize="14sp"
                        android:textColor="@color/text_dark"
                        android:fontFamily="sans-serif-light" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="improve visibility"
                        android:textSize="11sp"
                        android:textColor="@color/text_light"
                        android:fontFamily="sans-serif-light" />
                </LinearLayout>

                <Switch
                    android:id="@+id/switchHighContrast"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/primary_color"
                    android:trackTint="@color/primary_light" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0EEF5" />

            <!-- Large Text -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="large text"
                        android:textSize="14sp"
                        android:textColor="@color/text_dark"
                        android:fontFamily="sans-serif-light" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="increase text size"
                        android:textSize="11sp"
                        android:textColor="@color/text_light"
                        android:fontFamily="sans-serif-light" />
                </LinearLayout>

                <Switch
                    android:id="@+id/switchLargeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/primary_color"
                    android:trackTint="@color/primary_light" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="support"
            android:textSize="13sp"
            android:textColor="@color/text_light"
            android:fontFamily="sans-serif-light"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/feature_card_bg"
            android:orientation="vertical"
            android:padding="4dp"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:id="@+id/layoutHelpFaq"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="help and faq"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginStart="10dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="24sp"
                    android:textColor="@color/text_light"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Logout -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="log out"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-light"
            android:background="@drawable/outlined_button_bg"
            android:elevation="2dp"
            android:layout_marginBottom="24dp"/>

        <!-- NEW: App Version at bottom -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="mindbloom v1.0"
            android:textSize="12sp"
            android:textColor="@color/text_light"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>