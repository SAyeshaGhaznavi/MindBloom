<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0ECFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Breadcrumb -->
        <TextView
            android:id="@+id/tvBreadcrumb"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home > Progress"
            android:textColor="@color/text_light"
            android:textSize="12sp"
            android:layout_marginBottom="6dp"/>

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <ImageButton
                android:id="@+id/btnProgressBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_icon_bg"
                android:src="@drawable/icon_back"
                android:layout_centerVertical="true"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="My Progress "
                android:textColor="@color/text_dark"
                android:textSize="20sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- Stats row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/feature_card_bg"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTotalPoints"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 pts"
                    android:textColor="@color/primary_color"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Points"
                    android:textColor="@color/text_light"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_marginHorizontal="3dp"
                android:layout_weight="1"
                android:background="@drawable/feature_card_bg"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvQuizCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 quizzes"
                    android:textColor="@color/primary_color"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quizzes Done"
                    android:textColor="@color/text_light"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:background="@drawable/feature_card_bg"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/primary_color"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Day Streak"
                    android:textColor="@color/text_light"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Level card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:background="@drawable/soft_gradient_card_bg"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Current Level"
                android:textColor="@color/text_light"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Seedling"
                android:textColor="@color/text_dark"
                android:textSize="22sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/pbLevel"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:progressTint="@color/primary_color" />
        </LinearLayout>

        <!-- Subject progress -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Subject Progress"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:background="@drawable/feature_card_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Math -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:text="Math"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp" />

                <ProgressBar
                    android:id="@+id/barMath"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:layout_marginHorizontal="8dp"
                    android:layout_weight="1"
                    android:progressTint="@color/primary_color" />

                <TextView
                    android:id="@+id/tvMathScore"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:text="0%"
                    android:textColor="@color/text_light"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- English -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:text="Eng"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp" />

                <ProgressBar
                    android:id="@+id/barEnglish"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:layout_marginHorizontal="8dp"
                    android:layout_weight="1"
                    android:progressTint="@color/accent_pink" />

                <TextView
                    android:id="@+id/tvEnglishScore"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:text="0%"
                    android:textColor="@color/text_light"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Science -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:text="Sci"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp" />

                <ProgressBar
                    android:id="@+id/barScience"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:layout_marginHorizontal="8dp"
                    android:layout_weight="1"
                    android:progressTint="@color/accent_blue" />

                <TextView
                    android:id="@+id/tvScienceScore"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:text="0%"
                    android:textColor="@color/text_light"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Urdu -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:text="Urdu"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp" />

                <ProgressBar
                    android:id="@+id/barUrdu"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:layout_marginHorizontal="8dp"
                    android:layout_weight="1"
                    android:progressTint="@color/accent_green" />

                <TextView
                    android:id="@+id/tvUrduScore"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:text="0%"
                    android:textColor="@color/text_light"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- History -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:text="Hist"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp" />

                <ProgressBar
                    android:id="@+id/barHistory"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:layout_marginHorizontal="8dp"
                    android:layout_weight="1"
                    android:progressTint="@color/accent_yellow" />

                <TextView
                    android:id="@+id/tvHistoryScore"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:text="0%"
                    android:textColor="@color/text_light"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Art -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:text="Art"
                    android:textColor="@color/text_dark"
                    android:textSize="13sp" />

                <ProgressBar
                    android:id="@+id/barArt"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:layout_marginHorizontal="8dp"
                    android:layout_weight="1"
                    android:progressTint="@color/primary_light" />

                <TextView
                    android:id="@+id/tvArtScore"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:text="0%"
                    android:textColor="@color/text_light"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Badges -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Badges"
            android:textColor="@color/text_dark"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/feature_card_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/badgeFirstQuiz"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:gravity="center"
                        android:src="@drawable/bullseye" />

                    <TextView
                        android:id="@+id/tvBadgeFirstQuiz"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="First Quiz!"
                        android:textColor="@color/text_medium"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/badgeStreak3"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:gravity="center"
                        android:src="@drawable/fire" />

                    <TextView
                        android:id="@+id/tvBadgeStreak3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="3-Day Streak"
                        android:textColor="@color/text_medium"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/badgeStreak7"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:gravity="center"
                        android:src="@drawable/star" />

                    <TextView
                        android:id="@+id/tvBadgeStreak7"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="7-Day Streak"
                        android:textColor="@color/text_medium"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/badge100Points"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:gravity="center"
                        android:src="@drawable/anniversary"/>

                    <TextView
                        android:id="@+id/tvBadge100Points"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="100 Points"
                        android:textColor="@color/text_medium"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/badge500Points"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:gravity="center"
                        android:src="@drawable/trophy" />

                    <TextView
                        android:id="@+id/tvBadge500Points"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="500 Points"
                        android:textColor="@color/text_medium"
                        android:textSize="11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/badgeAllSubjects"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:gravity="center"
                        android:src="@drawable/sakura" />

                    <TextView
                        android:id="@+id/tvBadgeAllSubjects"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="All Subjects"
                        android:textColor="@color/text_medium"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>