<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Breadcrumb -->
        <TextView
            android:id="@+id/tvBreadcrumb"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home > Progress"
            android:textColor="@color/text_light"
            android:textSize="12sp"
            android:layout_marginBottom="6dp"/>

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <ImageButton
                android:id="@+id/btnProgressBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_icon_bg"
                android:src="@android:drawable/ic_media_previous"
                android:layout_centerVertical="true"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="My Progress 📊"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"/>
        </RelativeLayout>

        <!-- Stats row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/feature_card_bg"
                android:orientation="vertical"
                android:gravity="center"
                android:elevation="2dp">
                <TextView
                    android:id="@+id/tvTotalPoints"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ 0 pts"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_color"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Total Points" android:textSize="11sp" android:textColor="@color/text_light"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                android:background="@drawable/feature_card_bg"
                android:orientation="vertical"
                android:gravity="center"
                android:elevation="2dp">
                <TextView
                    android:id="@+id/tvQuizCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 quizzes"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_color"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Quizzes Done" android:textSize="11sp" android:textColor="@color/text_light"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/feature_card_bg"
                android:orientation="vertical"
                android:gravity="center"
                android:elevation="2dp">
                <TextView
                    android:id="@+id/tvStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥 0"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_color"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Day Streak" android:textSize="11sp" android:textColor="@color/text_light"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Level card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/soft_gradient_card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="20dp"
            android:elevation="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Current Level"
                android:textSize="12sp"
                android:textColor="@color/text_light"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌱 Seedling"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:layout_marginBottom="12dp"/>

            <ProgressBar
                android:id="@+id/pbLevel"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:progressTint="@color/primary_color"/>
        </LinearLayout>

        <!-- Subject progress -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Subject Progress"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/feature_card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="20dp"
            android:elevation="2dp">

            <!-- Math -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                    android:text="➕ Math" android:textSize="13sp" android:textColor="@color/text_dark"/>
                <ProgressBar android:id="@+id/barMath" style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp" android:layout_height="8dp" android:layout_weight="1"
                    android:progressTint="@color/primary_color" android:layout_marginHorizontal="8dp"/>
                <TextView android:id="@+id/tvMathScore" android:layout_width="36dp" android:layout_height="wrap_content"
                    android:text="0%" android:textSize="12sp" android:textColor="@color/text_light" android:gravity="end"/>
            </LinearLayout>

            <!-- English -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                    android:text="📝 Eng" android:textSize="13sp" android:textColor="@color/text_dark"/>
                <ProgressBar android:id="@+id/barEnglish" style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp" android:layout_height="8dp" android:layout_weight="1"
                    android:progressTint="@color/accent_pink" android:layout_marginHorizontal="8dp"/>
                <TextView android:id="@+id/tvEnglishScore" android:layout_width="36dp" android:layout_height="wrap_content"
                    android:text="0%" android:textSize="12sp" android:textColor="@color/text_light" android:gravity="end"/>
            </LinearLayout>

            <!-- Science -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                    android:text="🔬 Sci" android:textSize="13sp" android:textColor="@color/text_dark"/>
                <ProgressBar android:id="@+id/barScience" style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp" android:layout_height="8dp" android:layout_weight="1"
                    android:progressTint="@color/accent_blue" android:layout_marginHorizontal="8dp"/>
                <TextView android:id="@+id/tvScienceScore" android:layout_width="36dp" android:layout_height="wrap_content"
                    android:text="0%" android:textSize="12sp" android:textColor="@color/text_light" android:gravity="end"/>
            </LinearLayout>

            <!-- Urdu -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                    android:text="🇵🇰 Urdu" android:textSize="13sp" android:textColor="@color/text_dark"/>
                <ProgressBar android:id="@+id/barUrdu" style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp" android:layout_height="8dp" android:layout_weight="1"
                    android:progressTint="@color/accent_green" android:layout_marginHorizontal="8dp"/>
                <TextView android:id="@+id/tvUrduScore" android:layout_width="36dp" android:layout_height="wrap_content"
                    android:text="0%" android:textSize="12sp" android:textColor="@color/text_light" android:gravity="end"/>
            </LinearLayout>

            <!-- History -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="10dp">
                <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                    android:text="🏛️ Hist" android:textSize="13sp" android:textColor="@color/text_dark"/>
                <ProgressBar android:id="@+id/barHistory" style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp" android:layout_height="8dp" android:layout_weight="1"
                    android:progressTint="@color/accent_yellow" android:layout_marginHorizontal="8dp"/>
                <TextView android:id="@+id/tvHistoryScore" android:layout_width="36dp" android:layout_height="wrap_content"
                    android:text="0%" android:textSize="12sp" android:textColor="@color/text_light" android:gravity="end"/>
            </LinearLayout>

            <!-- Art -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="70dp" android:layout_height="wrap_content"
                    android:text="🎨 Art" android:textSize="13sp" android:textColor="@color/text_dark"/>
                <ProgressBar android:id="@+id/barArt" style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp" android:layout_height="8dp" android:layout_weight="1"
                    android:progressTint="@color/primary_light" android:layout_marginHorizontal="8dp"/>
                <TextView android:id="@+id/tvArtScore" android:layout_width="36dp" android:layout_height="wrap_content"
                    android:text="0%" android:textSize="12sp" android:textColor="@color/text_light" android:gravity="end"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Badges -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Badges 🏅"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/feature_card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:elevation="2dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/badgeFirstQuiz" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="🎯" android:textSize="32sp"
                        android:gravity="center"/>
                    <TextView android:id="@+id/tvBadgeFirstQuiz" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="First Quiz!" android:textSize="11sp"
                        android:textColor="@color/text_medium" android:gravity="center"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/badgeStreak3" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="🔥" android:textSize="32sp"
                        android:gravity="center"/>
                    <TextView android:id="@+id/tvBadgeStreak3" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="3-Day Streak" android:textSize="11sp"
                        android:textColor="@color/text_medium" android:gravity="center"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/badgeStreak7" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="🌟" android:textSize="32sp"
                        android:gravity="center"/>
                    <TextView android:id="@+id/tvBadgeStreak7" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="7-Day Streak" android:textSize="11sp"
                        android:textColor="@color/text_medium" android:gravity="center"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/badge100Points" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="💯" android:textSize="32sp"
                        android:gravity="center"/>
                    <TextView android:id="@+id/tvBadge100Points" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="100 Points" android:textSize="11sp"
                        android:textColor="@color/text_medium" android:gravity="center"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/badge500Points" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="🏆" android:textSize="32sp"
                        android:gravity="center"/>
                    <TextView android:id="@+id/tvBadge500Points" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="500 Points" android:textSize="11sp"
                        android:textColor="@color/text_medium" android:gravity="center"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/badgeAllSubjects" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="🌸" android:textSize="32sp"
                        android:gravity="center"/>
                    <TextView android:id="@+id/tvBadgeAllSubjects" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="All Subjects" android:textSize="11sp"
                        android:textColor="@color/text_medium" android:gravity="center"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
