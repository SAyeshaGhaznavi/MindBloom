<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MIND BLOOM"
            android:textSize="16sp"
            android:textColor="@color/primary_color"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.05"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Parent Settings"
            android:textSize="24sp"
            android:textColor="@color/text_dark"
            android:fontFamily="sans-serif-light"
            android:layout_marginBottom="28dp"/>

        <!-- Passcode Section -->
        <LinearLayout
            android:id="@+id/layoutPasscode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/feature_card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="24dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:drawableStart="@drawable/lock"
                android:drawablePadding="8dp"
                android:drawableTint="#FFC107"
                android:fontFamily="sans-serif-medium"
                android:gravity="center_vertical"
                android:text="Lock on Passcode"
                android:textColor="@color/text_dark"
                android:textSize="16sp" />

            <!-- 6 Pin Boxes -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="8dp">

                <View android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:layout_margin="4dp" android:background="#E0E0E0"/>
                <View android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:layout_margin="4dp" android:background="#E0E0E0"/>
                <View android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:layout_margin="4dp" android:background="#E0E0E0"/>
                <View android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:layout_margin="4dp" android:background="#E0E0E0"/>
                <View android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:layout_margin="4dp" android:background="#E0E0E0"/>
                <View android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:layout_margin="4dp" android:background="#E0E0E0"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="tap to set passcode"
                android:textSize="12sp"
                android:textColor="@color/text_light"
                android:fontFamily="sans-serif-light"
                android:layout_gravity="center"/>
        </LinearLayout>

        <!-- Menu Options -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/feature_card_bg"
            android:orientation="vertical"
            android:padding="4dp"
            android:layout_marginBottom="32dp">

            <!-- Manage Family Profile -->
            <LinearLayout
                android:id="@+id/itemFamilyProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:drawableStart="@drawable/parent"
                    android:drawablePadding="8dp"
                    android:drawableTint="#009688"
                    android:gravity="center_vertical"
                    android:textSize="22sp" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Manage Family Profile" android:textSize="15sp" android:textColor="@color/text_dark" android:fontFamily="sans-serif-light"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textSize="24sp" android:textColor="@color/text_light"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0EEF5" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"/>

            <!-- Set Screen Time Schedule -->
            <LinearLayout
                android:id="@+id/itemScreenTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:drawableStart="@drawable/timer"
                    android:drawablePadding="8dp"
                    android:drawableTint="#F44336"
                    android:gravity="center_vertical"
                    android:textSize="22sp" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Set Screen Time Schedule" android:textSize="15sp" android:textColor="@color/text_dark" android:fontFamily="sans-serif-light"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textSize="24sp" android:textColor="@color/text_light"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0EEF5" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"/>

            <!-- Filter App Content Categories -->
            <LinearLayout
                android:id="@+id/itemFilterContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:drawableStart="@drawable/guard"
                    android:drawablePadding="8dp"
                    android:drawableTint="#4CAF50"
                    android:gravity="center_vertical"
                    android:textSize="22sp" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Filter App Content Categories" android:textSize="15sp" android:textColor="@color/text_dark" android:fontFamily="sans-serif-light"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textSize="24sp" android:textColor="@color/text_light"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0EEF5" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"/>

            <!-- View Activity and Behavior Reports -->
            <LinearLayout
                android:id="@+id/itemReports"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:drawableStart="@drawable/progress"
                    android:drawablePadding="8dp"
                    android:drawableTint="#673AB7"
                    android:gravity="center_vertical"
                    android:textSize="22sp" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="View Activity and Behavior Reports" android:textSize="15sp" android:textColor="@color/text_dark" android:fontFamily="sans-serif-light"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textSize="24sp" android:textColor="@color/text_light"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0EEF5" android:layout_marginStart="16dp" android:layout_marginEnd="16dp"/>

            <!-- Edit Data and Privacy Settings -->
            <LinearLayout
                android:id="@+id/itemPrivacy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/lock"
                    android:drawableTint="#FFC107"
                    android:drawablePadding="8dp"
                    android:gravity="center_vertical"
                    android:textSize="22sp" android:layout_marginEnd="16dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Edit Data and Privacy Settings" android:textSize="15sp" android:textColor="@color/text_dark" android:fontFamily="sans-serif-light"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="›" android:textSize="24sp" android:textColor="@color/text_light"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Save Button -->
        <Button
            android:id="@+id/btnSaveConfig"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Save Configuration"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bubble_button_bg"
            android:elevation="2dp"/>

    </LinearLayout>
</ScrollView>