<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0ECFF"
    android:padding="24dp">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp">

        <ImageButton
            android:id="@+id/btnLessonBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/circle_icon_bg"
            android:src="@android:drawable/ic_media_previous"
            android:layout_centerVertical="true"/>

        <TextView
            android:id="@+id/tvLessonSubject"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Math Lesson"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#5e4d9e"/>

        <TextView
            android:id="@+id/tvLessonPageCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="1 / 3"
            android:textSize="13sp"
            android:textColor="#D500F9"/>
    </RelativeLayout>

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/lessonProgressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:progressTint="#FF6D00"
        android:layout_marginBottom="16dp"/>

    <!-- Lesson card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FFFFFF">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tvLessonTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lesson Title"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#6e60a3"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:id="@+id/tvLessonBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lesson content goes here."
                    android:textSize="16sp"
                    android:lineSpacingMultiplier="1.6"
                    android:textColor="#2654d4"/>
            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>

    <!-- Audio Player -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/feature_card_bg"
        android:orientation="vertical"
        android:padding="12dp"
        android:layout_marginBottom="8dp">

        <SeekBar
            android:id="@+id/audioSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progressTint="#FF6D00"
            android:thumbTint="#FF1744"
            android:max="225"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvAudioTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0:00"
                android:textSize="11sp"
                android:textColor="#D500F9"/>

            <ImageButton
                android:id="@+id/btnAudioPlay"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/circle_icon_bg"
                android:src="@android:drawable/ic_media_play"
                android:contentDescription="Play"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="3:45"
                android:textSize="11sp"
                android:textColor="#D500F9"
                android:gravity="end"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Multimedia Settings -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/feature_card_bg"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_marginBottom="8dp">

        <!-- Sign Language Stream -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Sign Language Stream"
                android:textSize="13sp"
                android:textColor="#2962FF"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Audio-Only Mode"
                android:textSize="11sp"
                android:textColor="#D500F9"
                android:layout_marginEnd="8dp"/>

            <Switch
                android:id="@+id/switchSignLanguage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Video Content Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Video Content"
            android:textSize="14sp"
            android:textColor="#2962FF"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- Subtitles -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Subtitles"
                android:textSize="13sp"
                android:textColor="#2962FF"/>

            <Switch
                android:id="@+id/switchSubtitles"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"/>
        </LinearLayout>

        <!-- Audio -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Audio"
                android:textSize="13sp"
                android:textColor="#2962FF"
                android:layout_marginEnd="12dp"/>

            <SeekBar
                android:id="@+id/seekBarAudio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:progressTint="#FF6D00"
                android:thumbTint="#FF1744"
                android:max="100"
                android:progress="75"/>
        </LinearLayout>

        <!-- Speed -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Speed"
                android:textSize="13sp"
                android:textColor="#2962FF"
                android:layout_marginEnd="12dp"/>

            <SeekBar
                android:id="@+id/seekBarSpeed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:progressTint="#FF6D00"
                android:thumbTint="#FF1744"
                android:max="200"
                android:progress="100"/>

            <TextView
                android:id="@+id/tvSpeedLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.0x"
                android:textSize="12sp"
                android:textColor="#D500F9"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Sign Language Interpreter -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Sign Language Interpreter"
                android:textSize="13sp"
                android:textColor="#2962FF"
                android:fontFamily="sans-serif-medium"/>

            <Switch
                android:id="@+id/switchInterpreter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#00C853"
                android:trackTint="#A5D6A7"/>
        </LinearLayout>

        <!-- Focus Timer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Focus Timer"
                android:textSize="14sp"
                android:textColor="#2962FF"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvFocusTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10:00"
                android:textSize="20sp"
                android:textColor="#FF1744"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:layout_marginEnd="12dp"/>

            <ImageButton
                android:id="@+id/btnTimerToggle"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/circle_icon_bg"
                android:src="@android:drawable/ic_media_play"
                android:contentDescription="Start Timer"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Navigation buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/btnLessonPrev"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="← Prev"
            android:backgroundTint="#FFD54F"
            android:textColor="#FF6D00"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnLessonNext"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Next →"
            android:backgroundTint="#FF6D00"
            android:textColor="#FFFFFF"
            android:textStyle="bold"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnTakeQuiz"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="10dp"
        android:text="🧠 Take the Quiz!"
        android:backgroundTint="#FF1744"
        android:textColor="#FFFFFF"
        android:textSize="17sp"
        android:textStyle="bold"
        android:visibility="gone"/>

</LinearLayout>