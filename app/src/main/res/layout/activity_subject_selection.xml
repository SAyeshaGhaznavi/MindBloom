<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Breadcrumb -->
        <TextView
            android:id="@+id/tvBreadcrumb"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home > Subjects"
            android:textColor="@color/text_light"
            android:textSize="12sp"
            android:layout_marginBottom="6dp"/>

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp">

            <ImageButton
                android:id="@+id/btnSubjectBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_icon_bg"
                android:src="@drawable/icon_back"
                android:layout_centerVertical="true"/>

            <TextView
                android:id="@+id/tvSubjectTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Pick Your Quiz 🧠"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark" />
        </RelativeLayout>

        <!-- Row 1: Math + English -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/cardMath"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/feature_card_bg"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="➕" android:textSize="32sp" android:layout_marginBottom="6dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Math" android:textSize="15sp" android:textStyle="bold"
                    android:textColor="@color/text_dark"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardEnglish"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/feature_card_bg"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📝" android:textSize="32sp" android:layout_marginBottom="6dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="English" android:textSize="15sp" android:textStyle="bold"
                    android:textColor="@color/text_dark"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Row 2: Science + Urdu -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/cardScience"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/feature_card_bg"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🔬" android:textSize="32sp" android:layout_marginBottom="6dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Science" android:textSize="15sp" android:textStyle="bold"
                    android:textColor="@color/text_dark"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardUrdu"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/feature_card_bg"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🇵🇰" android:textSize="32sp" android:layout_marginBottom="6dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Urdu" android:textSize="15sp" android:textStyle="bold"
                    android:textColor="@color/text_dark"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Row 3: History + Art -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/cardHistory"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/feature_card_bg"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🏛️" android:textSize="32sp" android:layout_marginBottom="6dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="History" android:textSize="15sp" android:textStyle="bold"
                    android:textColor="@color/text_dark"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardArt"
                android:layout_width="0dp"
                android:layout_height="110dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/feature_card_bg"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🎨" android:textSize="32sp" android:layout_marginBottom="6dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Art" android:textSize="15sp" android:textStyle="bold"
                    android:textColor="@color/text_dark"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
