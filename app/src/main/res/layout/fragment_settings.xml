<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_main">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Breadcrumb -->
            <TextView
                android:id="@+id/tvBreadcrumb"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home > Settings"
                android:textColor="@color/text_light"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <!-- Back + Title -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tvBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/circle_icon_bg"
                    android:src="@drawable/icon_back"
                    android:layout_centerVertical="true"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Settings "
                    android:textColor="@color/text_dark"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-light"/>
            </LinearLayout>

            <!-- 1. APPEARANCE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bubble_card_bg"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Appearance"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Dark Mode"
                        android:textColor="@color/text_dark"
                        android:textSize="15sp"/>

                    <Switch
                        android:id="@+id/switchDarkMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:thumbTint="@color/primary_color"
                        android:trackTint="@color/primary_light"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Font Size"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="A" android:textSize="12sp"
                        android:textColor="@color/text_medium" android:layout_marginBottom="12dp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="A" android:textSize="16sp"
                        android:textColor="@color/text_medium" android:gravity="center" android:layout_marginBottom="12dp"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="A" android:textSize="22sp"
                        android:textColor="@color/text_medium" android:gravity="end" android:layout_marginBottom="12dp"/>
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekBarFont"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="2"
                    android:progress="1"
                    android:progressTint="@color/primary_color"
                    android:thumbTint="@color/primary_color"/>

                <TextView
                    android:id="@+id/tvFontPreview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Preview: Medium text"
                    android:textColor="@color/text_medium"
                    android:textSize="16sp"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contrast"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="12dp"/>

                <RadioGroup android:id="@+id/rgContrast"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content">
                    <RadioButton android:id="@+id/rbNormalContrast"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/text_dark" android:buttonTint="@color/primary_color"
                        android:layout_marginBottom="4dp" android:text="Normal"/>
                    <RadioButton android:id="@+id/rbHighContrast"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/text_dark" android:buttonTint="@color/primary_color"
                        android:layout_marginBottom="4dp" android:text="High contrast"/>
                </RadioGroup>
            </LinearLayout>

            <!-- 2. AUDIO & SPEECH -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bubble_card_bg"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Audio and Speech"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textColor="@color/text_dark"
                        android:textSize="15sp" android:text="Read Aloud Automatically"/>
                    <Switch android:id="@+id/switchReadAloud" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:thumbTint="@color/primary_color"
                        android:trackTint="@color/primary_light"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Speech Speed"
                    android:textColor="@color/text_medium"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spinnerSpeechSpeed"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:backgroundTint="@color/primary_color"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Voice Selection"
                    android:textColor="@color/text_medium"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spinnerVoiceType"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:backgroundTint="@color/primary_color"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textColor="@color/text_dark"
                        android:textSize="15sp" android:text="Sound Effects"/>
                    <Switch android:id="@+id/switchSoundFx" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:thumbTint="@color/primary_color"
                        android:trackTint="@color/primary_light"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textColor="@color/text_dark"
                        android:textSize="15sp" android:text="Background Music"/>
                    <Switch android:id="@+id/switchBgMusic" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:thumbTint="@color/primary_color"
                        android:trackTint="@color/primary_light"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 3. VISUAL ACCESSIBILITY -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bubble_card_bg"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Visual Accessibility"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Color Blind Mode"
                    android:textColor="@color/text_medium"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spinnerColorBlind"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:backgroundTint="@color/primary_color"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textColor="@color/text_dark"
                        android:textSize="15sp" android:text="Reduce Motion"/>
                    <Switch android:id="@+id/switchReduceMotion" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:thumbTint="@color/primary_color"
                        android:trackTint="@color/primary_light"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textColor="@color/text_dark"
                        android:textSize="15sp" android:text="Focus Highlight Mode"/>
                    <Switch android:id="@+id/switchFocusHighlight" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:thumbTint="@color/primary_color"
                        android:trackTint="@color/primary_light"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textColor="@color/text_dark"
                        android:textSize="15sp" android:text="Reading Line Guide"/>
                    <Switch android:id="@+id/switchReadingGuide" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:thumbTint="@color/primary_color"
                        android:trackTint="@color/primary_light"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 4. COGNITIVE LOAD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bubble_card_bg"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Learning Comfort"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textColor="@color/text_dark"
                        android:textSize="15sp" android:text="Distraction-Free Mode"/>
                    <Switch android:id="@+id/switchDistractionFree" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:thumbTint="@color/primary_color"
                        android:trackTint="@color/primary_light"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hint Level"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="8dp"/>
                <RadioGroup android:id="@+id/rgHintLevel"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content">

                    <RadioButton android:id="@+id/rbBeginner" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/text_dark"
                        android:buttonTint="@color/primary_color" android:layout_marginBottom="4dp" android:text="Beginner"/>
                    <RadioButton android:id="@+id/rbGuided" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/text_dark"
                        android:buttonTint="@color/primary_color" android:layout_marginBottom="4dp" android:text="Guided"/>
                    <RadioButton android:id="@+id/rbIndependent" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/text_dark"
                        android:buttonTint="@color/primary_color" android:layout_marginBottom="4dp" android:text="Independent"/>
                </RadioGroup>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textColor="@color/text_dark"
                        android:textSize="15sp" android:text="Auto-Advance Questions"/>
                    <Switch android:id="@+id/switchAutoAdvance" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:thumbTint="@color/primary_color"
                        android:trackTint="@color/primary_light"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textColor="@color/text_dark"
                        android:textSize="15sp" android:text="Simple Language Mode"/>
                    <Switch android:id="@+id/switchSimpleLanguage" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:thumbTint="@color/primary_color"
                        android:trackTint="@color/primary_light"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 5. INTERACTION TIMING -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bubble_card_bg"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Timing and Control"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textColor="@color/text_dark"
                        android:textSize="15sp" android:text="Quiz Timer"/>
                    <Switch android:id="@+id/switchQuizTimer" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:thumbTint="@color/primary_color"
                        android:trackTint="@color/primary_light"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Extra Time"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="8dp"/>
                <RadioGroup
                    android:id="@+id/rgExtraTime"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content">


                    <RadioButton android:id="@+id/rbTimeNone" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/text_dark"
                        android:buttonTint="@color/primary_color" android:layout_marginBottom="4dp" android:text="None"/>
                    <RadioButton android:id="@+id/rbTime30" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/text_dark"
                        android:buttonTint="@color/primary_color" android:layout_marginBottom="4dp" android:text="+30 Seconds"/>
                    <RadioButton android:id="@+id/rbTime60" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/text_dark"
                        android:buttonTint="@color/primary_color" android:layout_marginBottom="4dp" android:text="+60 Seconds"/>
                </RadioGroup>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textColor="@color/text_dark"
                        android:textSize="15sp" android:text="Auto-Pause on Inactivity"/>
                    <Switch android:id="@+id/switchAutoPause" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:thumbTint="@color/primary_color"
                        android:trackTint="@color/primary_light"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textColor="@color/text_dark"
                        android:textSize="15sp" android:text="Double Tap Confirmation"/>
                    <Switch android:id="@+id/switchDoubleTap" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:thumbTint="@color/primary_color"
                        android:trackTint="@color/primary_light"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 6. LANGUAGE & CULTURAL -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bubble_card_bg"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Language and Culture"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="App Language"
                    android:textColor="@color/text_medium"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spinnerLanguage"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:backgroundTint="@color/primary_color"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textColor="@color/text_dark"
                        android:textSize="15sp" android:text="Bilingual Mode"/>
                    <Switch android:id="@+id/switchBilingual" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:thumbTint="@color/primary_color"
                        android:trackTint="@color/primary_light"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textColor="@color/text_dark"
                        android:textSize="15sp" android:text="Simplified English"/>
                    <Switch android:id="@+id/switchSimplifiedEnglish" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:thumbTint="@color/primary_color"
                        android:trackTint="@color/primary_light"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textColor="@color/text_dark"
                        android:textSize="15sp" android:text="Regional Examples"/>
                    <Switch android:id="@+id/switchRegionalExamples" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:thumbTint="@color/primary_color"
                        android:trackTint="@color/primary_light"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 7. KID SAFETY & PARENTS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bubble_card_bg"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Parental Controls"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnParentLock"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/primary_light"
                    android:textColor="@color/primary_color"
                    android:textAllCaps="false"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:text="🔒 Lock Parent Mode"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Content Filter (Age)"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="8dp"/>
                <RadioGroup android:id="@+id/rgContentFilter"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content">

                    <RadioButton android:id="@+id/rbAge3_5" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/text_dark"
                        android:buttonTint="@color/primary_color" android:layout_marginBottom="4dp" android:text="Ages 3-5"/>
                    <RadioButton android:id="@+id/rbAge6_8" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/text_dark"
                        android:buttonTint="@color/primary_color" android:layout_marginBottom="4dp" android:text="Ages 6-8"/>
                    <RadioButton android:id="@+id/rbAge9_12" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/text_dark"
                        android:buttonTint="@color/primary_color" android:layout_marginBottom="4dp" android:text="Ages 9-12"/>
                </RadioGroup>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Screen Time Limit"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="8dp"/>
                <SeekBar
                    android:id="@+id/seekBarScreenTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:progressTint="@color/primary_color"
                    android:thumbTint="@color/primary_color"
                    android:max="120"
                    android:progress="0"/>

                <Button
                    android:id="@+id/btnProgressReports"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/primary_light"
                    android:textColor="@color/primary_color"
                    android:textAllCaps="false"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:text="View Progress Reports"/>
            </LinearLayout>

            <!-- 8. NAVIGATION & USABILITY -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bubble_card_bg"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Navigation and Usability"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textColor="@color/text_dark"
                        android:textSize="15sp" android:text="Large Touch Mode"/>
                    <Switch android:id="@+id/switchLargeTouch" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:thumbTint="@color/primary_color"
                        android:trackTint="@color/primary_light"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textColor="@color/text_dark"
                        android:textSize="15sp" android:text="Gesture Navigation"/>
                    <Switch android:id="@+id/switchGestureNav" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:thumbTint="@color/primary_color"
                        android:trackTint="@color/primary_light"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textColor="@color/text_dark"
                        android:textSize="15sp" android:text="Haptic Feedback"/>
                    <Switch android:id="@+id/switchHaptic" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:thumbTint="@color/primary_color"
                        android:trackTint="@color/primary_light"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btnUndoAction"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/primary_light"
                    android:textColor="@color/primary_color"
                    android:textAllCaps="false"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:text="↩ Undo Last Action"/>
            </LinearLayout>

            <!-- 9. PERSONALIZATION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bubble_card_bg"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Personalization"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/primary_light"
                    android:textColor="@color/primary_color"
                    android:textAllCaps="false"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:text="Customize Avatar"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="App Theme"
                    android:textColor="@color/text_medium"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spinnerAppTheme"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:backgroundTint="@color/primary_color"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textColor="@color/text_dark"
                        android:textSize="15sp" android:text="Reward Animations"/>
                    <Switch android:id="@+id/switchRewardAnimations" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:thumbTint="@color/primary_color"
                        android:trackTint="@color/primary_light"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:textColor="@color/text_dark"
                        android:textSize="15sp" android:text="Daily Goal Reminder"/>
                    <Switch android:id="@+id/switchDailyGoal" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:thumbTint="@color/primary_color"
                        android:trackTint="@color/primary_light"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Help & FAQ link -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bubble_card_bg"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp"
                android:clickable="true"
                android:focusable="true"
                android:id="@+id/cardFaq"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=" FAQ and Help"
                    android:textColor="@color/text_dark"
                    android:textSize="15sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="→"
                    android:textColor="@color/primary_color"
                    android:textSize="18sp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>