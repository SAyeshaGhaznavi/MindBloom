        <activity
            android:name=".SubjectSelectionActivity"
            android:exported="false" />
        <activity
            android:name=".LessonActivity"
            android:exported="false" />
        <activity
            android:name=".QuizActivity"
            android:exported="false" />
        <activity
            android:name=".HomeworkActivity"
